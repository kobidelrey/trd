local KEY_FOLDER = "Dramaware"
local KEY_FILE   = "Dramaware/Dramaware_Key.txt"
local KEY_LENGTH = 32

if not isfolder(KEY_FOLDER) then
    makefolder(KEY_FOLDER)
end
task.wait(0.05)

local savedKey   = ""
local EnteredKey = ""

if isfile(KEY_FILE) then
    local ok, raw = pcall(readfile, KEY_FILE)
    if ok and raw then
        raw = raw:match("^%s*(.-)%s*$")
        if raw and #raw >= 8 then
            savedKey   = raw
            EnteredKey = raw
        else
            pcall(delfile, KEY_FILE)
        end
    end
end
task.wait(0.05)

local function submitKey(key)
    key = key:match("^%s*(.-)%s*$")

    if key == "" then
        Rayfield:Notify({
            Title = "No Key Entered",
            Content = "Please paste your key before submitting.",
            Duration = 3,
            Image = "alert-circle",
        })
        return
    end

    if not key:match("^[a-zA-Z0-9]+$") or #key ~= KEY_LENGTH then
        Rayfield:Notify({
            Title = "Invalid Format",
            Content = "That doesn't look like a valid key. Make sure you copied it correctly.",
            Duration = 4,
            Image = "x-circle",
        })
        return
    end

    pcall(writefile, KEY_FILE, key)
    savedKey = key
    task.wait(0.05)

    local ok, _ = pcall(function()
        getgenv().script_key = key
        rawset(_G, "script_key", key)
        loadstring(game:HttpGet("https://api.luarmor.net/files/v4/loaders/5a89b1cdea568e12c181f157541c1e32.lua"))()
    end)

    if not ok then
        savedKey   = ""
        EnteredKey = ""
        pcall(delfile, KEY_FILE)
        Rayfield:Notify({
            Title = "Invalid / Expired Key",
            Content = "Key rejected. Please get a new one.",
            Duration = 6,
            Image = "x-circle",
        })
    else
        Rayfield:Notify({
            Title = "Key Accepted!",
            Content = "Key saved! It will autofill next time.",
            Duration = 4,
            Image = "shield-check",
        })
    end
end

